generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum CompanionType {
  ROBOT
  PET
  ANIME_GIRL
  SPIRIT
  CUSTOM
}

enum CompanionMood {
  HAPPY
  NEUTRAL
  LONELY
  EXCITED
}

enum ActivityType {
  DAILY_CHECK_IN
  FEED_COMPANION
  PLAY_MINI_GAME
  REFLECTION_PROMPT
  ASK_COMPANION_QUESTION
}

enum AgentMemoryCategory {
  PREFERENCE
  GOAL
  FEEDBACK
  FACT
  DECISION
  PROJECT
}

enum AgentGoalStatus {
  ACTIVE
  PAUSED
  COMPLETE
}

enum AgentActionRunStatus {
  ACTIVE
  COMPLETE
  CANCELLED
}

enum ArchiveJobStatus {
  PENDING
  PROCESSING
  COMPLETE
  FAILED
}

model User {
  id            String      @id @default(cuid())
  walletAddress String      @unique @map("wallet_address")
  username      String?
  nonce         String
  createdAt     DateTime    @default(now()) @map("created_at")
  companions    Companion[]

  @@map("users")
}

model Companion {
  id                String               @id @default(cuid())
  userId            String               @map("user_id")
  blockchainId      String?              @unique @map("blockchain_id")
  name              String
  type              CompanionType
  avatarKey         String               @default("default") @map("avatar_key")
  customTypeName    String?              @map("custom_type_name")
  avatarImage       String?              @map("avatar_image")
  generatedPortrait String?              @map("generated_portrait")
  portraitPrompt    String?              @map("portrait_prompt")
  portraitVariants  Json?                @map("portrait_variants")
  level             Int                  @default(1)
  mood              CompanionMood        @default(NEUTRAL)
  relationshipLevel Int                  @default(1) @map("relationship_level")
  trustScore        Int                  @default(5) @map("trust_score")
  attachmentScore   Int                  @default(5) @map("attachment_score")
  evolutionStage    Int                  @default(1) @map("evolution_stage")
  createdAt         DateTime             @default(now()) @map("created_at")
  user              User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  memories          Memory[]
  agentMemories     AgentMemory[]
  agentProjects     AgentProject[]
  agentGoals        AgentGoal[]
  agentActions      AgentActionDefinition[]
  agentActionRuns   AgentActionRun[]
  personality       PersonalityProfile?
  agentProfile      AgentProfile?
  activityLogs      ActivityLog[]
  chatLogs          ChatLog[]
  memorySnapshots   MemorySnapshot[]
  archiveJobs       CompanionArchiveJob[]

  @@index([userId])
  @@map("companions")
}

model CompanionArchiveJob {
  id          String           @id @default(cuid())
  companionId String           @map("companion_id")
  reason      String
  status      ArchiveJobStatus @default(PENDING)
  attempts    Int              @default(0)
  rootHash    String?          @map("root_hash")
  lastError   String?          @map("last_error")
  requestedAt DateTime         @default(now()) @map("requested_at")
  processedAt DateTime?        @map("processed_at")
  companion   Companion        @relation(fields: [companionId], references: [id], onDelete: Cascade)

  @@index([status, requestedAt])
  @@index([companionId, status])
  @@map("companion_archive_jobs")
}

model AgentActionDefinition {
  id                   String   @id @default(cuid())
  companionId          String   @map("companion_id")
  key                  String
  label                String
  description          String
  starterQuestion      String   @map("starter_question")
  workflowInstructions String   @map("workflow_instructions")
  requiredInformation  String[] @default([]) @map("required_information")
  completionCriteria   String   @map("completion_criteria")
  safetyConstraints    String[] @default([]) @map("safety_constraints")
  source               String   @default("TEMPLATE")
  sortOrder            Int      @default(0) @map("sort_order")
  enabled              Boolean  @default(true)
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")
  companion            Companion @relation(fields: [companionId], references: [id], onDelete: Cascade)
  runs                 AgentActionRun[]

  @@unique([companionId, key])
  @@index([companionId, enabled, sortOrder])
  @@map("agent_action_definitions")
}

model AgentActionRun {
  id          String               @id @default(cuid())
  companionId String               @map("companion_id")
  actionId    String               @map("action_id")
  status      AgentActionRunStatus @default(ACTIVE)
  collectedData Json?              @map("collected_data")
  result      String?
  startedAt   DateTime             @default(now()) @map("started_at")
  completedAt DateTime?            @map("completed_at")
  companion   Companion            @relation(fields: [companionId], references: [id], onDelete: Cascade)
  action      AgentActionDefinition @relation(fields: [actionId], references: [id], onDelete: Cascade)

  @@index([companionId, status, startedAt])
  @@index([actionId, status])
  @@map("agent_action_runs")
}

model AgentProject {
  id          String          @id @default(cuid())
  companionId String          @map("companion_id")
  title       String
  description String?
  status      AgentGoalStatus @default(ACTIVE)
  priority    Int             @default(3)
  progress    Int             @default(0)
  nextStep    String?         @map("next_step")
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")
  companion   Companion       @relation(fields: [companionId], references: [id], onDelete: Cascade)
  goals       AgentGoal[]

  @@index([companionId, status, priority])
  @@map("agent_projects")
}

model AgentGoal {
  id          String          @id @default(cuid())
  companionId String          @map("companion_id")
  projectId   String?         @map("project_id")
  title       String
  status      AgentGoalStatus @default(ACTIVE)
  priority    Int             @default(3)
  progress    Int             @default(0)
  nextStep    String?         @map("next_step")
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")
  companion   Companion       @relation(fields: [companionId], references: [id], onDelete: Cascade)
  project     AgentProject?   @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([companionId, status, priority])
  @@index([projectId])
  @@map("agent_goals")
}

model AgentMemory {
  id          String              @id @default(cuid())
  companionId String              @map("companion_id")
  category    AgentMemoryCategory
  content     String
  importance  Int                 @default(5)
  confidence  Float               @default(1)
  tags        String[]            @default([])
  createdAt   DateTime            @default(now()) @map("created_at")
  lastUsedAt  DateTime?           @map("last_used_at")
  companion   Companion           @relation(fields: [companionId], references: [id], onDelete: Cascade)

  @@index([companionId, category, importance])
  @@map("agent_memories")
}

model AgentProfile {
  id              String   @id @default(cuid())
  companionId     String   @unique @map("companion_id")
  role            String
  templateId      String?  @map("template_id")
  mission         String
  scope           String[]
  boundaries      String[]
  expertise       String[]
  successCriteria String[] @map("success_criteria")
  responseStyle   String?  @map("response_style")
  autonomyLevel   String   @default("ADVISOR") @map("autonomy_level")
  validationStatus String  @default("APPROVED") @map("validation_status")
  validationNotes  String? @map("validation_notes")
  validatedAt      DateTime? @map("validated_at")
  profileVersion   Int      @default(1) @map("profile_version")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  companion       Companion @relation(fields: [companionId], references: [id], onDelete: Cascade)

  @@map("agent_profiles")
}

model Memory {
  id          String    @id @default(cuid())
  companionId String    @map("companion_id")
  memoryType  String    @map("memory_type")
  content     String
  importance  Int
  createdAt   DateTime  @default(now()) @map("created_at")
  companion   Companion @relation(fields: [companionId], references: [id], onDelete: Cascade)

  @@index([companionId, importance])
  @@map("memories")
}

model PersonalityProfile {
  id                 String    @id @default(cuid())
  companionId        String    @unique @map("companion_id")
  humorScore         Int       @default(50) @map("humor_score")
  supportivenessScore Int      @default(50) @map("supportiveness_score")
  curiosityScore     Int       @default(50) @map("curiosity_score")
  emotionalScore     Int       @default(50) @map("emotional_score")
  conciseScore       Int       @default(50) @map("concise_score")
  companion          Companion @relation(fields: [companionId], references: [id], onDelete: Cascade)

  @@map("personality_profiles")
}

model ActivityLog {
  id          String       @id @default(cuid())
  companionId String       @map("companion_id")
  activityType ActivityType @map("activity_type")
  createdAt   DateTime     @default(now()) @map("created_at")
  companion   Companion    @relation(fields: [companionId], references: [id], onDelete: Cascade)

  @@index([companionId, activityType, createdAt])
  @@map("activity_logs")
}

model ChatLog {
  id                String    @id @default(cuid())
  companionId       String    @map("companion_id")
  userMessage       String    @map("user_message")
  companionResponse String    @map("companion_response")
  structuredOutput  Json?     @map("structured_output")
  createdAt         DateTime  @default(now()) @map("created_at")
  companion         Companion @relation(fields: [companionId], references: [id], onDelete: Cascade)

  @@index([companionId, createdAt])
  @@map("chat_logs")
}

model MemorySnapshot {
  id              String    @id @default(cuid())
  companionId     String    @map("companion_id")
  rootHash        String    @map("root_hash")
  snapshotVersion Int       @map("snapshot_version")
  chainTransactionHash String? @map("chain_transaction_hash")
  anchoredAt      DateTime? @map("anchored_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  companion       Companion @relation(fields: [companionId], references: [id], onDelete: Cascade)

  @@index([companionId, snapshotVersion])
  @@map("memory_snapshots")
}
