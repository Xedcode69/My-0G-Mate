# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/mymate"

# Privy authentication and wallet connection
NEXT_PUBLIC_PRIVY_APP_ID=""
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=""

# Public 0G network and companion registry configuration
NEXT_PUBLIC_CHAIN_ID="16661"
NEXT_PUBLIC_ZERO_G_CHAIN_ID="16661"
NEXT_PUBLIC_COMPANION_REGISTRY_ADDRESS=""
NEXT_PUBLIC_BLOCKCHAIN_RPC_URL=""

# 0G Compute Router — primary companion and agent model provider
AI_PROVIDER="0g"
AI_FALLBACK_PROVIDER=""
ZERO_G_COMPUTE_BASE_URL="https://router-api.0g.ai/v1"
ZERO_G_COMPUTE_API_KEY=""
ZERO_G_COMPUTE_MODEL="0gm-1.0-35b-a3b"
ZERO_G_COMPUTE_MAX_TOKENS="4096"
ZERO_G_COMPUTE_TRUST_MODE="private"
ZERO_G_COMPUTE_VERIFY_TEE="true"

# Optional OpenAI-compatible fallback and portrait generation
LLM_BASE_URL="https://api.openai.com/v1"
LLM_API_KEY=""
LLM_MODEL="gpt-4o-mini"
IMAGE_API_KEY=""
IMAGE_MODEL="gpt-image-1"

# Archive encryption — Base64 encoding of exactly 32 random bytes
MEMORY_ENCRYPTION_KEY="replace-with-32-byte-base64-key"

# 0G Storage mainnet — use a dedicated, funded server wallet
ZERO_G_EVM_RPC="https://evmrpc.0g.ai"
ZERO_G_INDEXER_RPC="https://indexer-storage-turbo.0g.ai"
ZERO_G_STORAGE_PRIVATE_KEY=""

# Protected archive worker
CRON_SECRET="replace-with-a-long-random-secret"
ARCHIVE_DEBOUNCE_SECONDS="300"

# Optional legacy compatibility aliases; leave empty unless intentionally used
ZERO_G_STORAGE_RPC=""
BLOCKCHAIN_RPC_URL=""
COMPANION_REGISTRY_ADDRESS=""
